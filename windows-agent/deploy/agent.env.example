# Assessment Agent (Windows) — environment template
# Copy to C:\ProgramData\assessment-agent\agent.env
# Secret values (RABBITMQ_PASS) should be placed in a separate file:
#   C:\ProgramData\assessment-agent\agent.env.local
# Both files are written by deploy\env-setup.ps1 (idempotent — only prompts
# for keys with empty values).

# --- Broker connection ------------------------------------------------
RABBITMQ_HOST=rabbitmq.internal
RABBITMQ_PORT=5671
RABBITMQ_VHOST=/assessment
RABBITMQ_USER=agent-publisher
# RABBITMQ_PASS=  -- inject via agent.env.local

# --- TLS --------------------------------------------------------------
RABBITMQ_TLS_ENABLED=true
RABBITMQ_TLS_CA_PATH=C:\ProgramData\assessment-agent\ca.pem
RABBITMQ_TLS_VERIFY_PEER=true
RABBITMQ_TLS_VERIFY_HOSTNAME=true
# RABBITMQ_TLS_CERT_PATH=C:\ProgramData\assessment-agent\client.pem    # optional mTLS
# RABBITMQ_TLS_KEY_PATH=C:\ProgramData\assessment-agent\client.key

# --- Heartbeat --------------------------------------------------------
RABBITMQ_HEARTBEAT_SEC=60
RABBITMQ_CONFIRM_TIMEOUT_SEC=5

# --- Exchange / routing keys -----------------------------------------
RABBITMQ_EXCHANGE=assessment
RABBITMQ_ROUTING_KEY_INVENTORY=server.inventory
RABBITMQ_ROUTING_KEY_METRICS=server.metrics
RABBITMQ_ROUTING_KEY_ERROR=server.error

# --- Collector cadence ------------------------------------------------
AGENT_INTERVAL_SEC=60
AGENT_INVENTORY_REFRESH_SEC=3600
