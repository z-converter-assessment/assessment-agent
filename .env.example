RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=admin
RABBITMQ_EXCHANGE=assessment
RABBITMQ_QUEUE=server.metrics
RABBITMQ_ROUTING_KEY=metrics

# Loop interval in seconds. 0 means one-shot.
AGENT_INTERVAL_SEC=10

# Optional: comma-separated list. If unset, agent queries https://api.ipify.org.
# AGENT_EXTERNAL_IP=1.2.3.4

# Optional: override reported hostname. Used by multi-agent tests to
# distinguish processes running on the same host.
# AGENT_HOSTNAME_OVERRIDE=test-agent-1
