# =====================================================================
# Local development defaults. Production must override host, credentials,
# vhost, port, and TLS-related fields. Inject secrets from Vault/KMS, not
# from this file.
# =====================================================================

# --- Broker connection ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
# Production: use /assessment instead of /
RABBITMQ_VHOST=/

# --- Credentials ---
# Production: use the agent-publisher role.
RABBITMQ_USER=admin
RABBITMQ_PASS=admin

# AMQP heartbeat (seconds). RabbitMQ recommends 60.
# Reference: https://www.rabbitmq.com/heartbeats.html
RABBITMQ_HEARTBEAT_SEC=60

# Wall-clock deadline (seconds) for the publisher-confirm ACK from the
# broker. Increase if the broker is under heavy load and falsely times out.
RABBITMQ_CONFIRM_TIMEOUT_SEC=5

# --- TLS (production) ---
# Set to 1 to enable AMQPS. When enabled, set RABBITMQ_PORT=5671.
RABBITMQ_TLS_ENABLED=0
# RABBITMQ_TLS_CA_PATH=/etc/assessment-agent/ca.pem
# RABBITMQ_TLS_VERIFY_PEER=1
# RABBITMQ_TLS_VERIFY_HOSTNAME=1
# Optional mTLS:
# RABBITMQ_TLS_CERT_PATH=/etc/assessment-agent/client.pem
# RABBITMQ_TLS_KEY_PATH=/etc/assessment-agent/client.key

# --- Routing contract (must match the consumer side) ---
RABBITMQ_EXCHANGE=assessment
RABBITMQ_ROUTING_KEY_INVENTORY=server.inventory
RABBITMQ_ROUTING_KEY_METRICS=server.metrics
RABBITMQ_ROUTING_KEY_ERROR=server.error

# --- Agent runtime ---
# Loop interval in seconds. 0 means one-shot (cron / systemd timer).
AGENT_INTERVAL_SEC=60

# Optional: comma-separated list. If unset, the agent queries cloud
# metadata (AWS IMDSv2 / Azure / GCP) with a 1s timeout. On failure
# ip_external becomes null.
# AGENT_EXTERNAL_IP=1.2.3.4

# Optional: override repo